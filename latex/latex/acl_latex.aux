\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces One denoising step under schema \texttt  {\{"count":int,\,"label":str\}}. \textbf  {LAVE} \citep  {zhang2026lookaheadthenverifyreliableconstraineddecoding} (left) samples $K$ random completions at each frontier token, accepting it only when $\geq \!1$ suffix is valid—stochastic and $K\!\times $ more expensive per token, hitting the 120\,s per-instance timeout on hard schemas. \textbf  {Dgrammar} (right) runs \texttt  {compute\_mask} on the incremental FSM state and unmasks an entire block under that mask in one forward pass, overlapped with the next mask computation; the result is deterministic.}}{6}{figure.caption.15}\protected@file@percent }
\newlabel{fig:denoise-compare}{{3}{6}{One denoising step under schema \texttt {\{"count":int,\,"label":str\}}. \textbf {LAVE} \citep {zhang2026lookaheadthenverifyreliableconstraineddecoding} (left) samples $K$ random completions at each frontier token, accepting it only when $\geq \!1$ suffix is valid—stochastic and $K\!\times $ more expensive per token, hitting the 120\,s per-instance timeout on hard schemas. \textbf {Dgrammar} (right) runs \texttt {compute\_mask} on the incremental FSM state and unmasks an entire block under that mask in one forward pass, overlapped with the next mask computation; the result is deterministic}{figure.caption.15}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \texttt  {jsb\_medium} results (seed~0, $T{=}128$ steps). All three methods are evaluated on the same $n{=}511$ matched instances; 75 instances are skipped by all methods due to grammar-invalid schemas (LAVE: immediate parse error; Dgrammar/DPGrammar: silently skipped by \textsc  {llguidance}). $^\S  $~LAVE resamples count lookahead verification draws; Dgrammar/DPGrammar resamples count token re-mask events.}}{6}{table.caption.19}\protected@file@percent }
\newlabel{tab:main}{{1}{6}{\texttt {jsb\_medium} results (seed~0, $T{=}128$ steps). All three methods are evaluated on the same $n{=}511$ matched instances; 75 instances are skipped by all methods due to grammar-invalid schemas (LAVE: immediate parse error; Dgrammar/DPGrammar: silently skipped by \textsc {llguidance}). $^\S $~LAVE resamples count lookahead verification draws; Dgrammar/DPGrammar resamples count token re-mask events}{table.caption.19}{}}
