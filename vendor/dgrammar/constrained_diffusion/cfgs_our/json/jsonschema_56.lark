%llguidance {}

AMOUNT_REQUESTED_KV: "\"amountRequested\"" SPACE ":" SPACE NUMBER
APPLICANT_DETAILS: "{" SPACE APPLICANT_DETAILS_NAME_KV "," SPACE APPLICANT_DETAILS_INCOME_KV "," SPACE APPLICANT_DETAILS_CREDIT_SCORE_KV "}" SPACE
APPLICANT_DETAILS_CREDIT_SCORE_KV: "\"creditScore\"" SPACE ":" SPACE INTEGER
APPLICANT_DETAILS_INCOME_KV: "\"income\"" SPACE ":" SPACE NUMBER
APPLICANT_DETAILS_KV: "\"applicantDetails\"" SPACE ":" SPACE APPLICANT_DETAILS
APPLICANT_DETAILS_NAME_KV: "\"name\"" SPACE ":" SPACE STRING
APPLICATION_ID_KV: "\"applicationID\"" SPACE ":" SPACE STRING

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

DECIMAL_PART: /[0-9]/{1,16}
INTEGER: "-"? INTEGRAL_PART SPACE

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

LOAN_TYPE_KV: "\"loanType\"" SPACE ":" SPACE STRING
NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
REPAYMENT_SCHEDULE_KV: "\"repaymentSchedule\"" SPACE ":" SPACE STRING
start: SPACE  "{" SPACE APPLICATION_ID_KV "," SPACE APPLICANT_DETAILS_KV "," SPACE LOAN_TYPE_KV "," SPACE AMOUNT_REQUESTED_KV "," SPACE REPAYMENT_SCHEDULE_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
