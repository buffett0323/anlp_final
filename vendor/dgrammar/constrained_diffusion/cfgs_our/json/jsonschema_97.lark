%llguidance {}

BASE_PREMIUM_KV: "\"basePremium\"" SPACE ":" SPACE NUMBER

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

DECIMAL_PART: /[0-9]/{1,16}
INTEGER: "-"? INTEGRAL_PART SPACE

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
POLICY_ID_KV: "\"policyId\"" SPACE ":" SPACE STRING
RISK_FACTORS: "{" SPACE RISK_FACTORS_AGE_KV "," SPACE RISK_FACTORS_LOCATION_KV "," SPACE RISK_FACTORS_VEHICLE_TYPE_KV "}" SPACE
RISK_FACTORS_AGE_KV: "\"age\"" SPACE ":" SPACE INTEGER
RISK_FACTORS_KV: "\"riskFactors\"" SPACE ":" SPACE RISK_FACTORS
RISK_FACTORS_LOCATION_KV: "\"location\"" SPACE ":" SPACE STRING
RISK_FACTORS_VEHICLE_TYPE_KV: "\"vehicleType\"" SPACE ":" SPACE STRING
start: SPACE  "{" SPACE POLICY_ID_KV "," SPACE BASE_PREMIUM_KV "," SPACE RISK_FACTORS_KV "," SPACE TOTAL_PREMIUM_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
TOTAL_PREMIUM_KV: "\"totalPremium\"" SPACE ":" SPACE NUMBER
FENCE: "```"
