%llguidance {}

BUDGET_MANAGEMENT: "{" SPACE BUDGET_MANAGEMENT_MONTHLY_INCOME_KV "," SPACE BUDGET_MANAGEMENT_EXPENSES_KV "," SPACE BUDGET_MANAGEMENT_SAVINGS_GOAL_KV "}" SPACE
BUDGET_MANAGEMENT_EXPENSES: "[" SPACE (BUDGET_MANAGEMENT_EXPENSES_ITEM ("," SPACE BUDGET_MANAGEMENT_EXPENSES_ITEM)*)? "]" SPACE
BUDGET_MANAGEMENT_EXPENSES_ITEM: "{" SPACE BUDGET_MANAGEMENT_EXPENSES_ITEM_CATEGORY_KV "," SPACE BUDGET_MANAGEMENT_EXPENSES_ITEM_AMOUNT_KV "}" SPACE
BUDGET_MANAGEMENT_EXPENSES_ITEM_AMOUNT_KV: "\"amount\"" SPACE ":" SPACE NUMBER
BUDGET_MANAGEMENT_EXPENSES_ITEM_CATEGORY_KV: "\"category\"" SPACE ":" SPACE STRING
BUDGET_MANAGEMENT_EXPENSES_KV: "\"expenses\"" SPACE ":" SPACE BUDGET_MANAGEMENT_EXPENSES
BUDGET_MANAGEMENT_KV: "\"BudgetManagement\"" SPACE ":" SPACE BUDGET_MANAGEMENT
BUDGET_MANAGEMENT_MONTHLY_INCOME_KV: "\"monthly_income\"" SPACE ":" SPACE NUMBER
BUDGET_MANAGEMENT_SAVINGS_GOAL_KV: "\"savings_goal\"" SPACE ":" SPACE NUMBER

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

DECIMAL_PART: /[0-9]/{1,16}

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
start: SPACE  "{" SPACE BUDGET_MANAGEMENT_KV? "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
