%llguidance {}

HOME_IMPROVEMENT: "{" SPACE HOME_IMPROVEMENT_ROOM_INTEREST_KV "," SPACE HOME_IMPROVEMENT_BUDGET_KV "," SPACE HOME_IMPROVEMENT_PREFERRED_STYLE_KV "," SPACE HOME_IMPROVEMENT_PROJECT_IDEAS_KV "}" SPACE
HOME_IMPROVEMENT_BUDGET_KV: "\"budget\"" SPACE ":" SPACE NUMBER
HOME_IMPROVEMENT_KV: "\"HomeImprovement\"" SPACE ":" SPACE HOME_IMPROVEMENT
HOME_IMPROVEMENT_PREFERRED_STYLE_KV: "\"preferred_style\"" SPACE ":" SPACE STRING
HOME_IMPROVEMENT_PROJECT_IDEAS: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
HOME_IMPROVEMENT_PROJECT_IDEAS_KV: "\"project_ideas\"" SPACE ":" SPACE HOME_IMPROVEMENT_PROJECT_IDEAS
HOME_IMPROVEMENT_ROOM_INTEREST_KV: "\"room_interest\"" SPACE ":" SPACE STRING

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

DECIMAL_PART: /[0-9]/{1,16}

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
start: SPACE  "{" SPACE HOME_IMPROVEMENT_KV? "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
