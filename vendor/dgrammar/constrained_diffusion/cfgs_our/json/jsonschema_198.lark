%llguidance {}

CENTER_NAME_KV: "\"centerName\"" SPACE ":" SPACE STRING

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

INSURANCE_ACCEPTED: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
INSURANCE_ACCEPTED_KV: "\"insuranceAccepted\"" SPACE ":" SPACE INSURANCE_ACCEPTED
start: SPACE  "{" SPACE CENTER_NAME_KV "," SPACE SPECIALTY_KV "," SPACE TREATMENT_MODALITIES_KV "," SPACE INSURANCE_ACCEPTED_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
SPECIALTY_KV: "\"specialty\"" SPACE ":" SPACE STRING
STRING: "\"" CHAR* "\"" SPACE
TREATMENT_MODALITIES: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
TREATMENT_MODALITIES_KV: "\"treatmentModalities\"" SPACE ":" SPACE TREATMENT_MODALITIES
FENCE: "```"
