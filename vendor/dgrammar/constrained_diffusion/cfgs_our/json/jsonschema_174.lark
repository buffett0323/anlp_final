%llguidance {}

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

COMPONENT_ID_KV: "\"componentID\"" SPACE ":" SPACE STRING
COMPONENT_NAME_KV: "\"componentName\"" SPACE ":" SPACE STRING
DECIMAL_PART: /[0-9]/{1,16}

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
start: SPACE  "{" SPACE COMPONENT_ID_KV "," SPACE COMPONENT_NAME_KV "," SPACE SPECS_KV "," SPACE SUPPLIER_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
SPECS: "{" SPACE SPECS_DIMENSION_KV "," SPACE SPECS_WEIGHT_KV "}" SPACE
SPECS_DIMENSION_KV: "\"dimension\"" SPACE ":" SPACE STRING
SPECS_KV: "\"specs\"" SPACE ":" SPACE SPECS
SPECS_WEIGHT_KV: "\"weight\"" SPACE ":" SPACE NUMBER
STRING: "\"" CHAR* "\"" SPACE
SUPPLIER: "{" SPACE SUPPLIER_NAME_KV "," SPACE SUPPLIER_CONTACT_KV "}" SPACE
SUPPLIER_CONTACT_KV: "\"contact\"" SPACE ":" SPACE STRING
SUPPLIER_KV: "\"supplier\"" SPACE ":" SPACE SUPPLIER
SUPPLIER_NAME_KV: "\"name\"" SPACE ":" SPACE STRING
FENCE: "```"
