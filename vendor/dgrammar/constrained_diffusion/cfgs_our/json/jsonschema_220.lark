%llguidance {}

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

COVERAGE_DETAILS: "{" SPACE COVERAGE_DETAILS_COVERAGE_AMOUNT_KV "," SPACE COVERAGE_DETAILS_EFFECTIVE_DATE_KV "," SPACE COVERAGE_DETAILS_EXPIRATION_DATE_KV "}" SPACE
COVERAGE_DETAILS_COVERAGE_AMOUNT_KV: "\"coverageAmount\"" SPACE ":" SPACE NUMBER
COVERAGE_DETAILS_EFFECTIVE_DATE: DATE_STRING
COVERAGE_DETAILS_EFFECTIVE_DATE_KV: "\"effectiveDate\"" SPACE ":" SPACE COVERAGE_DETAILS_EFFECTIVE_DATE
COVERAGE_DETAILS_EXPIRATION_DATE: DATE_STRING
COVERAGE_DETAILS_EXPIRATION_DATE_KV: "\"expirationDate\"" SPACE ":" SPACE COVERAGE_DETAILS_EXPIRATION_DATE
COVERAGE_DETAILS_KV: "\"coverageDetails\"" SPACE ":" SPACE COVERAGE_DETAILS
DATE: /[0-9]/{4,4} "-" ("0" /[1-9]/ | "1" /[0-2]/) "-" ("0" /[1-9]/ | /[1-2]/ /[0-9]/ | "3" /[0-1]/)
DATE_STRING: "\"" DATE "\"" SPACE
DECIMAL_PART: /[0-9]/{1,16}
INSURER: "{" SPACE INSURER_INSURER_NAME_KV "," SPACE INSURER_INSURER_CONTACT_KV "}" SPACE
INSURER_INSURER_CONTACT_KV: "\"insurerContact\"" SPACE ":" SPACE STRING
INSURER_INSURER_NAME_KV: "\"insurerName\"" SPACE ":" SPACE STRING
INSURER_KV: "\"insurer\"" SPACE ":" SPACE INSURER

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
POLICY_NUMBER_KV: "\"policyNumber\"" SPACE ":" SPACE STRING
PREMIUM_KV: "\"premium\"" SPACE ":" SPACE NUMBER
start: SPACE  "{" SPACE POLICY_NUMBER_KV "," SPACE COVERAGE_DETAILS_KV "," SPACE PREMIUM_KV "," SPACE INSURER_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
