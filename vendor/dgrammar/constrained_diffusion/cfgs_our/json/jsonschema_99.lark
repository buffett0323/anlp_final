%llguidance {}

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

CUSTOMER_ID_KV: "\"customerID\"" SPACE ":" SPACE STRING
DATE: /[0-9]/{4,4} "-" ("0" /[1-9]/ | "1" /[0-2]/) "-" ("0" /[1-9]/ | /[1-2]/ /[0-9]/ | "3" /[0-1]/)
DATE_STRING: "\"" DATE "\"" SPACE
DECIMAL_PART: /[0-9]/{1,16}

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
start: SPACE  "{" SPACE CUSTOMER_ID_KV "," SPACE VEHICLE_ID_KV "," SPACE SERVICE_RECORDS_KV "," SPACE TOTAL_SPENT_KV "}" SPACE FENCE?
SERVICE_RECORDS: "[" SPACE (SERVICE_RECORDS_ITEM ("," SPACE SERVICE_RECORDS_ITEM)*)? "]" SPACE
SERVICE_RECORDS_ITEM: "{" SPACE SERVICE_RECORDS_ITEM_SERVICE_DATE_KV "," SPACE SERVICE_RECORDS_ITEM_DESCRIPTION_KV "," SPACE SERVICE_RECORDS_ITEM_COST_KV "}" SPACE
SERVICE_RECORDS_ITEM_COST_KV: "\"cost\"" SPACE ":" SPACE NUMBER
SERVICE_RECORDS_ITEM_DESCRIPTION_KV: "\"description\"" SPACE ":" SPACE STRING
SERVICE_RECORDS_ITEM_SERVICE_DATE: DATE_STRING
SERVICE_RECORDS_ITEM_SERVICE_DATE_KV: "\"serviceDate\"" SPACE ":" SPACE SERVICE_RECORDS_ITEM_SERVICE_DATE
SERVICE_RECORDS_KV: "\"serviceRecords\"" SPACE ":" SPACE SERVICE_RECORDS
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
TOTAL_SPENT_KV: "\"totalSpent\"" SPACE ":" SPACE NUMBER
VEHICLE_ID_KV: "\"vehicleID\"" SPACE ":" SPACE STRING
FENCE: "```"
