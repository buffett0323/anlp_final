%llguidance {}

AVERAGE_DELIVERY_TIME_KV: "\"averageDeliveryTime\"" SPACE ":" SPACE NUMBER
DECIMAL_PART: /[0-9]/{1,16}
INTEGER: "-"? INTEGRAL_PART SPACE

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
ON_TIME_DELIVERY_RATE_KV: "\"onTimeDeliveryRate\"" SPACE ":" SPACE NUMBER
PENDING_SHIPMENTS_KV: "\"pendingShipments\"" SPACE ":" SPACE INTEGER
start: SPACE  "{" SPACE TOTAL_SHIPMENTS_KV "," SPACE ON_TIME_DELIVERY_RATE_KV "," SPACE AVERAGE_DELIVERY_TIME_KV "," SPACE PENDING_SHIPMENTS_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
TOTAL_SHIPMENTS_KV: "\"totalShipments\"" SPACE ":" SPACE INTEGER
FENCE: "```"
