%llguidance {}

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

DATE: /[0-9]/{4,4} "-" ("0" /[1-9]/ | "1" /[0-2]/) "-" ("0" /[1-9]/ | /[1-2]/ /[0-9]/ | "3" /[0-1]/)
DATE_STRING: "\"" DATE "\"" SPACE
MANUFACTURING_DATE: DATE_STRING
MANUFACTURING_DATE_KV: "\"manufacturingDate\"" SPACE ":" SPACE MANUFACTURING_DATE
PRODUCT_CODE_KV: "\"productCode\"" SPACE ":" SPACE STRING
PRODUCT_NAME_KV: "\"productName\"" SPACE ":" SPACE STRING
start: SPACE  "{" SPACE PRODUCT_NAME_KV "," SPACE PRODUCT_CODE_KV "," SPACE SPECIFICATIONS_KV "," SPACE MANUFACTURING_DATE_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
SPECIFICATIONS: "{" SPACE SPECIFICATIONS_SIZE_KV "," SPACE SPECIFICATIONS_CAPACITY_KV "," SPACE SPECIFICATIONS_POWER_CONSUMPTION_KV "}" SPACE
SPECIFICATIONS_CAPACITY_KV: "\"capacity\"" SPACE ":" SPACE STRING
SPECIFICATIONS_KV: "\"specifications\"" SPACE ":" SPACE SPECIFICATIONS
SPECIFICATIONS_POWER_CONSUMPTION_KV: "\"powerConsumption\"" SPACE ":" SPACE STRING
SPECIFICATIONS_SIZE_KV: "\"size\"" SPACE ":" SPACE STRING
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
