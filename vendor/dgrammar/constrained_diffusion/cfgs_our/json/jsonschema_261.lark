%llguidance {}

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

FIREWALL_RULES: "[" SPACE (FIREWALL_RULES_ITEM ("," SPACE FIREWALL_RULES_ITEM)*)? "]" SPACE
FIREWALL_RULES_ITEM: "{" SPACE FIREWALL_RULES_ITEM_RULE_ID_KV "," SPACE FIREWALL_RULES_ITEM_ACTION_KV "," SPACE FIREWALL_RULES_ITEM_PROTOCOL_KV "," SPACE FIREWALL_RULES_ITEM_PORT_RANGE_KV "}" SPACE
FIREWALL_RULES_ITEM_ACTION: ("\"Allow\"" | "\"Deny\"" | "\"Limit\"") SPACE
FIREWALL_RULES_ITEM_ACTION_KV: "\"action\"" SPACE ":" SPACE FIREWALL_RULES_ITEM_ACTION
FIREWALL_RULES_ITEM_PORT_RANGE_KV: "\"portRange\"" SPACE ":" SPACE STRING
FIREWALL_RULES_ITEM_PROTOCOL_KV: "\"protocol\"" SPACE ":" SPACE STRING
FIREWALL_RULES_ITEM_RULE_ID_KV: "\"ruleId\"" SPACE ":" SPACE STRING
FIREWALL_RULES_KV: "\"firewallRules\"" SPACE ":" SPACE FIREWALL_RULES
POLICY_NAME_KV: "\"policyName\"" SPACE ":" SPACE STRING
start: SPACE  "{" SPACE POLICY_NAME_KV "," SPACE FIREWALL_RULES_KV "," SPACE VPN_REQUIREMENTS_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
VPN_REQUIREMENTS: "{" SPACE VPN_REQUIREMENTS_VPN_TYPE_KV "," SPACE VPN_REQUIREMENTS_ENCRYPTION_STANDARDS_KV "}" SPACE
VPN_REQUIREMENTS_ENCRYPTION_STANDARDS_KV: "\"encryptionStandards\"" SPACE ":" SPACE STRING
VPN_REQUIREMENTS_KV: "\"vpnRequirements\"" SPACE ":" SPACE VPN_REQUIREMENTS
VPN_REQUIREMENTS_VPN_TYPE_KV: "\"vpnType\"" SPACE ":" SPACE STRING
FENCE: "```"
