%llguidance {}

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

COMPANY_NAME_KV: "\"companyName\"" SPACE ":" SPACE STRING
CONTACT_INFO: "{" SPACE CONTACT_INFO_PHONE_KV "," SPACE CONTACT_INFO_EMAIL_KV "," SPACE CONTACT_INFO_ADDRESS_KV "}" SPACE
CONTACT_INFO_ADDRESS_KV: "\"address\"" SPACE ":" SPACE STRING
CONTACT_INFO_EMAIL_KV: "\"email\"" SPACE ":" SPACE STRING
CONTACT_INFO_KV: "\"contactInfo\"" SPACE ":" SPACE CONTACT_INFO
CONTACT_INFO_PHONE_KV: "\"phone\"" SPACE ":" SPACE STRING
DISTRIBUTOR_ID_KV: "\"distributorID\"" SPACE ":" SPACE STRING
PRODUCT_CATEGORIES: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
PRODUCT_CATEGORIES_KV: "\"productCategories\"" SPACE ":" SPACE PRODUCT_CATEGORIES
start: SPACE  "{" SPACE DISTRIBUTOR_ID_KV "," SPACE COMPANY_NAME_KV "," SPACE CONTACT_INFO_KV "," SPACE PRODUCT_CATEGORIES_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
