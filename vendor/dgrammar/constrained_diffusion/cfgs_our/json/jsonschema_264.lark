%llguidance {}

CATEGORY_KV: "\"category\"" SPACE ":" SPACE STRING

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

END_DATE_KV: "\"endDate\"" SPACE ":" SPACE STRING
LOCATION_KV: "\"location\"" SPACE ":" SPACE STRING
LOCATION_REST: ("," SPACE RECURRENCE_DATE_KV)? RECURRENCE_DATE_REST
RECURRENCE_DATE_KV: "\"recurrenceDate\"" SPACE ":" SPACE STRING
RECURRENCE_DATE_REST: ("," SPACE CATEGORY_KV)?
start: SPACE  "{" SPACE START_DATE_KV "," SPACE END_DATE_KV "," SPACE SUMMARY_KV ("," SPACE (LOCATION_KV LOCATION_REST | RECURRENCE_DATE_KV RECURRENCE_DATE_REST | CATEGORY_KV))? "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
START_DATE_KV: "\"startDate\"" SPACE ":" SPACE STRING
STRING: "\"" CHAR* "\"" SPACE
SUMMARY_KV: "\"summary\"" SPACE ":" SPACE STRING
FENCE: "```"
