%llguidance {}

APPLICANT_DETAILS: "{" SPACE APPLICANT_DETAILS_FIRST_NAME_KV "," SPACE APPLICANT_DETAILS_LAST_NAME_KV "," SPACE APPLICANT_DETAILS_DATE_OF_BIRTH_KV "," SPACE APPLICANT_DETAILS_EMPLOYMENT_STATUS_KV "}" SPACE
APPLICANT_DETAILS_DATE_OF_BIRTH: DATE_STRING
APPLICANT_DETAILS_DATE_OF_BIRTH_KV: "\"dateOfBirth\"" SPACE ":" SPACE APPLICANT_DETAILS_DATE_OF_BIRTH
APPLICANT_DETAILS_EMPLOYMENT_STATUS_KV: "\"employmentStatus\"" SPACE ":" SPACE STRING
APPLICANT_DETAILS_FIRST_NAME_KV: "\"firstName\"" SPACE ":" SPACE STRING
APPLICANT_DETAILS_KV: "\"applicantDetails\"" SPACE ":" SPACE APPLICANT_DETAILS
APPLICANT_DETAILS_LAST_NAME_KV: "\"lastName\"" SPACE ":" SPACE STRING

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

CREDIT_SCORE_KV: "\"creditScore\"" SPACE ":" SPACE INTEGER
DATE: /[0-9]/{4,4} "-" ("0" /[1-9]/ | "1" /[0-2]/) "-" ("0" /[1-9]/ | /[1-2]/ /[0-9]/ | "3" /[0-1]/)
DATE_STRING: "\"" DATE "\"" SPACE
DECIMAL_PART: /[0-9]/{1,16}
INTEGER: "-"? INTEGRAL_PART SPACE

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

LOAN_AMOUNT_KV: "\"loanAmount\"" SPACE ":" SPACE NUMBER
NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
start: SPACE  "{" SPACE APPLICANT_DETAILS_KV "," SPACE LOAN_AMOUNT_KV "," SPACE CREDIT_SCORE_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
