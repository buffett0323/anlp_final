%llguidance {}

OEMCOMPATIBILITY: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
OEMCOMPATIBILITY_KV: "\"OEMCompatibility\"" SPACE ":" SPACE OEMCOMPATIBILITY

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

COMPONENT_ID_KV: "\"componentID\"" SPACE ":" SPACE STRING
COMPONENT_NAME_KV: "\"componentName\"" SPACE ":" SPACE STRING
start: SPACE  "{" SPACE COMPONENT_ID_KV "," SPACE COMPONENT_NAME_KV "," SPACE SPECIFICATIONS_KV "," SPACE OEMCOMPATIBILITY_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
SPECIFICATIONS: "{" SPACE SPECIFICATIONS_SIZE_KV "," SPACE SPECIFICATIONS_WEIGHT_KV "," SPACE SPECIFICATIONS_POWER_REQUIREMENTS_KV "}" SPACE
SPECIFICATIONS_KV: "\"specifications\"" SPACE ":" SPACE SPECIFICATIONS
SPECIFICATIONS_POWER_REQUIREMENTS_KV: "\"powerRequirements\"" SPACE ":" SPACE STRING
SPECIFICATIONS_SIZE_KV: "\"size\"" SPACE ":" SPACE STRING
SPECIFICATIONS_WEIGHT_KV: "\"weight\"" SPACE ":" SPACE STRING
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
