%llguidance {}

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

CURRENT_PROFICIENCY_KV: "\"current_proficiency\"" SPACE ":" SPACE STRING
LEARNING_GOALS: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
LEARNING_GOALS_KV: "\"learning_goals\"" SPACE ":" SPACE LEARNING_GOALS
RECOMMENDED_RESOURCES: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
RECOMMENDED_RESOURCES_KV: "\"recommended_resources\"" SPACE ":" SPACE RECOMMENDED_RESOURCES
start: SPACE  "{" SPACE TARGET_LANGUAGE_KV "," SPACE CURRENT_PROFICIENCY_KV "," SPACE LEARNING_GOALS_KV "," SPACE RECOMMENDED_RESOURCES_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
TARGET_LANGUAGE_KV: "\"target_language\"" SPACE ":" SPACE STRING
FENCE: "```"
