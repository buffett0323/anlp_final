%llguidance {}

FITNESS_TRACKING: "{" SPACE FITNESS_TRACKING_CURRENT_HEALTH_STATUS_KV "," SPACE FITNESS_TRACKING_HEALTH_GOALS_KV "," SPACE FITNESS_TRACKING_RECOMMENDED_ROUTINES_KV "}" SPACE
FITNESS_TRACKING_CURRENT_HEALTH_STATUS: "{" SPACE FITNESS_TRACKING_CURRENT_HEALTH_STATUS_WEIGHT_KV "," SPACE FITNESS_TRACKING_CURRENT_HEALTH_STATUS_HEIGHT_KV "," SPACE FITNESS_TRACKING_CURRENT_HEALTH_STATUS_HEART_RATE_KV "}" SPACE
FITNESS_TRACKING_CURRENT_HEALTH_STATUS_HEART_RATE_KV: "\"heart_rate\"" SPACE ":" SPACE NUMBER
FITNESS_TRACKING_CURRENT_HEALTH_STATUS_HEIGHT_KV: "\"height\"" SPACE ":" SPACE NUMBER
FITNESS_TRACKING_CURRENT_HEALTH_STATUS_KV: "\"current_health_status\"" SPACE ":" SPACE FITNESS_TRACKING_CURRENT_HEALTH_STATUS
FITNESS_TRACKING_CURRENT_HEALTH_STATUS_WEIGHT_KV: "\"weight\"" SPACE ":" SPACE NUMBER
FITNESS_TRACKING_HEALTH_GOALS: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
FITNESS_TRACKING_HEALTH_GOALS_KV: "\"health_goals\"" SPACE ":" SPACE FITNESS_TRACKING_HEALTH_GOALS
FITNESS_TRACKING_KV: "\"FitnessTracking\"" SPACE ":" SPACE FITNESS_TRACKING
FITNESS_TRACKING_RECOMMENDED_ROUTINES: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
FITNESS_TRACKING_RECOMMENDED_ROUTINES_KV: "\"recommended_routines\"" SPACE ":" SPACE FITNESS_TRACKING_RECOMMENDED_ROUTINES

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

DECIMAL_PART: /[0-9]/{1,16}

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
start: SPACE  "{" SPACE FITNESS_TRACKING_KV? "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
