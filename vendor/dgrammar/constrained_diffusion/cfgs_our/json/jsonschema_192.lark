%llguidance {}

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

DECIMAL_PART: /[0-9]/{1,16}

INTEGRAL_PART: /[0]/
     | /[1-9]/ /[0-9]/{0,15}

NUMBER: "-"? INTEGRAL_PART ("." DECIMAL_PART)? (/[eE]/ /[-+]/? INTEGRAL_PART)? SPACE
PROJECT_ID_KV: "\"projectID\"" SPACE ":" SPACE STRING
PROPOSAL_ID_KV: "\"proposalID\"" SPACE ":" SPACE STRING
PROPOSED_COST_KV: "\"proposedCost\"" SPACE ":" SPACE NUMBER
start: SPACE  "{" SPACE PROPOSAL_ID_KV "," SPACE PROJECT_ID_KV "," SPACE SUBMITTER_DETAILS_KV "," SPACE PROPOSED_COST_KV "," SPACE TIMELINE_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
SUBMITTER_DETAILS: "{" SPACE SUBMITTER_DETAILS_NAME_KV "," SPACE SUBMITTER_DETAILS_COMPANY_KV "," SPACE SUBMITTER_DETAILS_CONTACT_INFO_KV "}" SPACE
SUBMITTER_DETAILS_COMPANY_KV: "\"company\"" SPACE ":" SPACE STRING
SUBMITTER_DETAILS_CONTACT_INFO_KV: "\"contactInfo\"" SPACE ":" SPACE STRING
SUBMITTER_DETAILS_KV: "\"submitterDetails\"" SPACE ":" SPACE SUBMITTER_DETAILS
SUBMITTER_DETAILS_NAME_KV: "\"name\"" SPACE ":" SPACE STRING
TIMELINE_KV: "\"timeline\"" SPACE ":" SPACE STRING
FENCE: "```"
