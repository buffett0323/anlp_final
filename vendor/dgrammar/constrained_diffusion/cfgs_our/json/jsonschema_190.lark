%llguidance {}

ALTERNATIVE_0: "{" SPACE ((ALTERNATIVE_0_DEVICE_TYPE_KV ALTERNATIVE_0_DEVICE_TYPE_REST | ALTERNATIVE_0_BRAND_KV ALTERNATIVE_0_BRAND_REST | ALTERNATIVE_0_MODEL_KV ALTERNATIVE_0_MODEL_REST | ALTERNATIVE_0_SCREEN_SIZE_KV))? "}" SPACE
ALTERNATIVE_0_BRAND_KV: "\"brand\"" SPACE ":" SPACE STRING
ALTERNATIVE_0_BRAND_REST: ("," SPACE ALTERNATIVE_0_MODEL_KV)? ALTERNATIVE_0_MODEL_REST
ALTERNATIVE_0_DEVICE_TYPE: "\"smartphone\"" SPACE
ALTERNATIVE_0_DEVICE_TYPE_KV: "\"deviceType\"" SPACE ":" SPACE ALTERNATIVE_0_DEVICE_TYPE
ALTERNATIVE_0_DEVICE_TYPE_REST: ("," SPACE ALTERNATIVE_0_BRAND_KV)? ALTERNATIVE_0_BRAND_REST
ALTERNATIVE_0_MODEL_KV: "\"model\"" SPACE ":" SPACE STRING
ALTERNATIVE_0_MODEL_REST: ("," SPACE ALTERNATIVE_0_SCREEN_SIZE_KV)?
ALTERNATIVE_0_SCREEN_SIZE_KV: "\"screenSize\"" SPACE ":" SPACE STRING
ALTERNATIVE_1: "{" SPACE ((ALTERNATIVE_1_DEVICE_TYPE_KV ALTERNATIVE_1_DEVICE_TYPE_REST | ALTERNATIVE_1_BRAND_KV ALTERNATIVE_1_BRAND_REST | ALTERNATIVE_1_MODEL_KV ALTERNATIVE_1_MODEL_REST | ALTERNATIVE_1_PROCESSOR_KV ALTERNATIVE_1_PROCESSOR_REST | ALTERNATIVE_1_RAMSIZE_KV))? "}" SPACE
ALTERNATIVE_1_RAMSIZE_KV: "\"RAMSize\"" SPACE ":" SPACE STRING
ALTERNATIVE_1_BRAND_KV: "\"brand\"" SPACE ":" SPACE STRING
ALTERNATIVE_1_BRAND_REST: ("," SPACE ALTERNATIVE_1_MODEL_KV)? ALTERNATIVE_1_MODEL_REST
ALTERNATIVE_1_DEVICE_TYPE: "\"laptop\"" SPACE
ALTERNATIVE_1_DEVICE_TYPE_KV: "\"deviceType\"" SPACE ":" SPACE ALTERNATIVE_1_DEVICE_TYPE
ALTERNATIVE_1_DEVICE_TYPE_REST: ("," SPACE ALTERNATIVE_1_BRAND_KV)? ALTERNATIVE_1_BRAND_REST
ALTERNATIVE_1_MODEL_KV: "\"model\"" SPACE ":" SPACE STRING
ALTERNATIVE_1_MODEL_REST: ("," SPACE ALTERNATIVE_1_PROCESSOR_KV)? ALTERNATIVE_1_PROCESSOR_REST
ALTERNATIVE_1_PROCESSOR_KV: "\"processor\"" SPACE ":" SPACE STRING
ALTERNATIVE_1_PROCESSOR_REST: ("," SPACE ALTERNATIVE_1_RAMSIZE_KV)?

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

start: SPACE  ALTERNATIVE_0 FENCE?
     | ALTERNATIVE_1

SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
FENCE: "```"
