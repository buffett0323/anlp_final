%llguidance {}

CHAR: /[^"\\\x7F\x00-\x1F]/
     | /[\\]/ (/["\\bfnrt]/ | "u" /[0-9a-fA-F]/{4,4})

CURRENT_LOCATION_KV: "\"current_location\"" SPACE ":" SPACE STRING
PREFERRED_UNITS_KV: "\"preferred_units\"" SPACE ":" SPACE STRING
RECOMMENDED_ACTIVITIES: "[" SPACE (STRING ("," SPACE STRING)*)? "]" SPACE
RECOMMENDED_ACTIVITIES_KV: "\"recommended_activities\"" SPACE ":" SPACE RECOMMENDED_ACTIVITIES
start: SPACE  "{" SPACE CURRENT_LOCATION_KV "," SPACE PREFERRED_UNITS_KV "," SPACE WEATHER_FORECAST_KV "," SPACE RECOMMENDED_ACTIVITIES_KV "}" SPACE FENCE?
SPACE: /[ \t\n\r]/*
STRING: "\"" CHAR* "\"" SPACE
WEATHER_FORECAST_KV: "\"weather_forecast\"" SPACE ":" SPACE STRING
FENCE: "```"
